{
  "name": "home-ops-finance",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Workbook-driven personal finance tracker and migration tooling.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "import:workbook": "node --experimental-strip-types src/workbook-importer.ts",
    "bootstrap:mappings": "node --experimental-strip-types src/bootstrap-import-mappings.ts",
    "apply:review-state": "node --experimental-strip-types src/apply-review-state.ts",
    "report:draft": "node --experimental-strip-types src/draft-report.ts",
    "report:reviewed": "node --experimental-strip-types src/draft-report.ts --reviewed",
    "plan:months": "node --experimental-strip-types src/monthly-engine.ts",
    "plan:reviewed": "node --experimental-strip-types src/monthly-engine.ts --reviewed",
    "build:dashboard": "node --experimental-strip-types src/build-dashboard.ts",
    "serve:app": "node --experimental-strip-types src/serve-app.ts",
    "serve:app:server": "HOME_OPS_FINANCE_SERVER_MODE=1 HOME_OPS_FINANCE_HOST=0.0.0.0 node --experimental-strip-types src/serve-app.ts"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.2"
  }
}
