{
  "name": "home-ops-backup-control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first backup verification and stale-job tracker.",
  "scripts": {
    "check": "npm run typecheck && npm test",
    "backup": "node --experimental-strip-types src/cli.ts",
    "record": "node --experimental-strip-types src/cli.ts record",
    "start": "node --experimental-strip-types src/server.ts",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@home-ops/framework": "file:../../../home-ops-framework"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.2"
  }
}
