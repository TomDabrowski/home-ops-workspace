{
  "dataDir": "/path/to/private/home-ops-watcher/data",
  "targets": [
    {
      "id": "router",
      "label": "Router Admin",
      "kind": "http",
      "url": "http://example.home.invalid",
      "expectedStatus": 200,
      "staleAfterHours": 2,
      "timeoutMs": 3000
    },
    {
      "id": "nas-ssh",
      "label": "NAS SSH",
      "kind": "tcp",
      "host": "192.0.2.10",
      "port": 22,
      "timeoutMs": 3000
    },
    {
      "id": "backup-control",
      "label": "Backup Control",
      "kind": "json-status",
      "url": "http://127.0.0.1:4321/api/status",
      "statusPath": "summary.status",
      "staleAfterHours": 2,
      "timeoutMs": 3000
    }
  ]
}
